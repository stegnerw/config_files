# i3blocks configuration
# https://github.com/vivien/i3blocks
#
# Block scripts live in ~/.config/i3blocks/scripts/
# Click any block to get full details via dunst notification.
# Signal a block to force refresh: pkill -RTMIN+<signal> i3blocks

# [global]
# Most blocks support middle-click for more info
separator=true
separator_block_width=15
markup=pango
command=$HOME/.config/i3blocks/scripts/$BLOCK_NAME

[volume]
# Left click: mixer | Right click: mute | Scroll: volume
interval=1
signal=1

[notif]
# Left click: toggle notifications
interval=1
signal=2

[pomodoro]
interval=1
signal=5

[updates]
interval=300

[network]
interval=10
signal=3

[bat]
interval=30
signal=4

[load]
interval=5

[temp]
interval=5

[ram]
interval=5

[disk]
instance=/
interval=60

[datetime]
command=date '+%Y-%m-%d %H:%M:%S'
interval=1
